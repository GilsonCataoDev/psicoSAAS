# ─── API Backend ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── Modo mock (sem backend) ───────────────────────────────────────────────
# "true" usa dados fictícios localmente — nunca usar em produção
VITE_USE_MOCK=false

# ─── Analytics (PostHog) ──────────────────────────────────────────────────
# https://posthog.com → Criar projeto → Project Settings → Project API Key
# Deixar vazio para desabilitar analytics (ex: em desenvolvimento)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Base URL (GitHub Pages) ──────────────────────────────────────────────
# Só necessário para deploy em subpath (ex: /psicosaas/)
# BASE_URL=/psicosaas/
