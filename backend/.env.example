NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psicosaas

# JWT — troque para um segredo forte em produção
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend
FRONTEND_URL=http://localhost:3000

# WhatsApp (Evolution API ou similar)
WHATSAPP_API_URL=https://your-evolution-api.com
WHATSAPP_API_KEY=your-api-key

# Pagamentos (Mercado Pago)
MERCADOPAGO_ACCESS_TOKEN=your-access-token

# Criptografia de anotações clínicas
ENCRYPTION_KEY=32-char-hex-key-for-aes-256-gcm
