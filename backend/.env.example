NODE_ENV=development
PORT=3001

# ─── Banco de dados ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psicosaas

# ─── Autenticação JWT ──────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ─── Assinatura digital de documentos ─────────────────────────────────────
# Gerar com: openssl rand -hex 32
# NUNCA alterar em produção — invalida todas as assinaturas existentes!
SIGN_SECRET=your-sign-secret-key-change-in-production-min-32-chars

# ─── Asaas (pagamentos SaaS) ───────────────────────────────────────────────
# Sandbox: https://sandbox.asaas.com → Minha Conta → Integrações → Chave API
# Produção: https://asaas.com → Minha Conta → Integrações → Chave API
ASAAS_API_KEY=$aact_SEU_TOKEN_AQUI

# Token secreto configurado em: Asaas → Configurações → Webhooks → Token de acesso
ASAAS_WEBHOOK_TOKEN=seu-token-webhook-secreto

# ─── E-mail transacional (Resend) ─────────────────────────────────────────
# https://resend.com → API Keys → Criar chave
# Domínio verificado necessário para produção (ex: @seudominio.com.br)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=PsicoSaaS <noreply@seudominio.com.br>

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────
# Self-hosted: https://github.com/EvolutionAPI/evolution-api
# Ou serviço gerenciado: https://uazapi.com / https://wppconnect.io
WHATSAPP_API_URL=https://your-evolution-api.com
WHATSAPP_API_KEY=your-api-key
WHATSAPP_INSTANCE=psicosaas-instance

# ─── URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://gilsoncataodev.github.io

# ─── Monitoramento de erros (Sentry) ──────────────────────────────────────
# https://sentry.io → Criar projeto Node.js → Copiar DSN
# Deixar vazio em desenvolvimento para não enviar erros locais
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXX

# ─── Criptografia de anotações clínicas (AES-256) ─────────────────────────
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=32-char-hex-key-for-aes-256-gcm
